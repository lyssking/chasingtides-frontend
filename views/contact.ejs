<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Support | ChasingTides</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <!-- Update the Header Navbar links inside contact.ejs -->
<nav class="navbar navbar-expand-lg bg-white border-bottom py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <i class="bi bi-tsunami text-success fs-4"></i>
            <span>ChasingTides</span>
        </a>
        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav gap-2">
                <!-- 🛠️ LINK FIX -->
                <li class="nav-item"><a class="nav-link" href="/#catalog">Catalog</a></li>
                <li class="nav-item"><a class="nav-link active" href="/contact">Support</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Update the Breadcrumbs block inside contact.ejs -->
<div class="breadcrumb-wrapper py-2">
    <div class="container">
        <nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item"><a href="/">Products</a></li>
    <li class="breadcrumb-item active" aria-current="page"><%= product.title %></li>
  </ol>
</nav>
    </div>
</div>

    <main class="container my-5" style="max-width: 950px;">
        <div class="text-center mb-5">
            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill mb-2 fw-bold tracking-wider">LABORATORY SUPPORT</span>
            <h1 class="fw-extrabold text-dark display-6">Connect With Our Research Specialists</h1>
            <p class="text-secondary lead-sm">Master your cellular current. Drop us a line regarding catalog specifications or order tracking updates.</p>
        </div>

        <div class="row g-4">
            <div class="col-12 col-md-7">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <form action="/contact-submit" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Full Name</label>
                            <input type="text" class="form-control rounded-3" name="name" placeholder="Alex Rivers" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Email Address</label>
                            <input type="email" class="form-control rounded-3" name="email" placeholder="alex@domain.com" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary">Message / Inquiry Scope</label>
                            <textarea class="form-control rounded-3" name="message" rows="5" placeholder="Please detail any specific configuration or compound batch purity questions..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-conversion btn-lg w-100 py-2 shadow-sm">
                            <i class="bi bi-send-fill me-2"></i> Dispatch Message
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-12 col-md-5">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100 d-flex flex-column justify-content-between">
                    <div>
                        <h3 class="h5 fw-bold mb-4 text-dark">Corporate Office</h3>
                        
                        <div class="d-flex gap-3 mb-4">
                            <div class="fs-4 text-success"><i class="bi bi-envelope-at-fill"></i></div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">Secure Support Email</h6>
                                <p class="text-secondary small mb-0">support@chasingtideslabs.com</p>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mb-4">
                            <div class="fs-4 text-success"><i class="bi bi-clock-history"></i></div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">Operating Hours</h6>
                                <p class="text-secondary small mb-0">Monday – Friday: 9 AM – 5 PM MST</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-light rounded-4 p-3 border-start border-success border-4 mt-3">
                        <h6 class="fw-bold text-dark mb-1"><i class="bi bi-activity text-success me-1"></i> Quality Assurance</h6>
                        <p class="small text-secondary mb-0">All batches undergo independent 3rd-party HPLC testing to certify structural authenticity and ultra-high purity levels.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-center py-4 text-muted small border-top bg-white mt-5">
        &copy; 2026 ChasingTides Labs. All rights reserved. Master Your Cellular Current.
    </footer>

</body>
</html>