<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.title %> | Premium Performance</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Paste this exactly inside your <head> block in product-page.ejs -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23059669'><path d='M.003 12.5a.5.5 0 0 0 .5.5H15.5a.5.5 0 0 0 0-1H.503a.5.5 0 0 0-.5.5zm.754-4.246a.385.385 0 0 0 .54 0l1.13-1.13a.385.385 0 0 1 .54 0l3.83 3.83a.385.385 0 0 0 .54 0l5.385-5.386a.385.385 0 0 1 .54 0l1.13 1.13a.385.385 0 0 0 .54 0 .385.385 0 0 0 0-.54l-1.13-1.13a1.385 1.385 0 0 0-1.96 0L8.13 10.13a.385.385 0 0 1-.54 0L3.76 6.3a1.385 1.385 0 0 0-1.96 0L.757 7.714a.385.385 0 0 0 0 .54z'/></svg>">
</head>
<body>

<!-- Update the Header Navbar links inside product-page.ejs -->
<nav class="navbar navbar-expand-lg bg-white border-bottom py-3 shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <i class="bi bi-tsunami text-success fs-4"></i>
            <span>ChasingTides</span>
        </a>
        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav gap-2">
                <!-- 🛠️ LINK FIX: Points straight to the homepage catalog section -->
                <li class="nav-item"><a class="nav-link" href="/#catalog">Catalog</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">Support</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Update the Breadcrumbs block inside product-page.ejs -->
<div class="breadcrumb-wrapper py-2">
    <div class="container">
        <nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item"><a href="/">Products</a></li>
    <li class="breadcrumb-item active" aria-current="page"><%= product.title %></li>
  </ol>
</nav>
    </div>
</div>

    <div class="bg-brand-primary text-center py-2 small shadow-sm">
        ⚡ CLINICALLY DOSED. THIRD-PARTY LAB TESTED. ZERO ARTIFICIAL FILLERS.
    </div>

    <main class="container my-5 py-3">
        <div class="row g-5 align-items-center">
            
            <div class="col-12 col-md-6">
    <div class="product-showcase shadow-sm">
        <% if (product.image && product.image !== '') { %>
            <img src="<%= product.image %>" 
                 alt="<%= product.title %>" 
                 class="product-image img-fluid rounded-4 shadow-sm">
        <% } else { %>
            <div class="p-5 text-center text-muted bg-light border rounded-4">
                [ No product image asset uploaded in CMS ]
            </div>
        <% } %>
    </div>
</div>
            <div class="col-12 col-md-6">
                <span class="text-brand-accent text-uppercase fw-bold tracking-wider small">Premium Series</span>
                <h1 class="display-5 fw-black text-dark mt-1 mb-3"><%= product.title %></h1>
                
                <div class="text-secondary mb-4">
    <% if (product.descriptionHtml) { %>
        <% if (typeof product.descriptionHtml === 'string') { %>
            <%- product.descriptionHtml %>
        <% } else if (Array.isArray(product.descriptionHtml)) { %>
            <% product.descriptionHtml.forEach(block => { %>
                <% if (block.type === 'paragraph') { %>
                    <p class="lead-sm"><%= block.children.map(c => c.text).join('') %></p>
                <% } %>
            <% }) %>
        <% } %>
    <% } else { %>
        <p>Premium formulated ingredients designed to support your athletic performance and daily recovery goals.</p>
    <% } %>
</div>

                <div class="border-top pt-4 mt-4">
                    <div class="d-flex align-items-baseline mb-4">
    <span class="fs-2 fw-bold text-dark">$<%= product.price %></span>
    <span class="text-muted ms-2 small">USD</span>
</div>

                    <form action="/checkout" method="POST">
    
    <input type="hidden" name="productId" value="<%= product.documentId %>">
    
    <div class="d-grid">
        <button type="submit" class="btn btn-conversion btn-lg">
            Optimize My Health Journey
        </button>
    </div>
</form>
                    
                    <div class="text-center mt-3">
                        <small class="text-muted">🔒 Encrypted checkouts processed securely by Shopify</small>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>